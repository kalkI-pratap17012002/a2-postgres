# Copy this file to .env and adjust as needed. .env itself is gitignored.

# Which repository the app boots with: "postgres" (default) or "memory".
REPOSITORY=postgres

# Used when running the app directly on your host (npm run dev), against
# the Postgres container's published port. docker-compose.yml overrides
# this to point at the "db" service hostname when running the full stack
# with `docker compose up`.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/a2

PORT=3000

# Stretch: optional Redis ping. Leave unset to skip.
REDIS_URL=redis://localhost:6379
